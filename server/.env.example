# --- Server ---
# Port the backend listens on. On Railway this is provided automatically.
PORT=3000

# Host to bind. Defaults to 127.0.0.1 in dev and 0.0.0.0 in production.
# HOST=127.0.0.1

# Public origin of the deployed app (also serves the SPA in single-service mode).
# In local dev this must be a loopback IP (127.0.0.1), NOT "localhost".
# In production this defaults to https://$RAILWAY_PUBLIC_DOMAIN when that is set.
PUBLIC_URL=http://127.0.0.1:3000

# Where the browser app is served. In local dev this is the Vite server.
# In production (single service) it defaults to PUBLIC_URL, so leave it unset.
FRONTEND_URL=http://127.0.0.1:5173

# Secret used to sign the app-session cookie. Set a long random value in production.
COOKIE_SECRET=change-me-to-a-long-random-string

# --- Production OAuth (confidential client) ---
# Set these as Railway service variables (do NOT commit real values).
# NODE_ENV=production
#
# URL serving the client metadata document. Defaults to PUBLIC_URL/client-metadata.json,
# so you usually do NOT need to set this explicitly.
# CLIENT_ID=https://your-app.up.railway.app/client-metadata.json
#
# One or more ES256 private keys (PKCS#8 PEM), used to sign client assertions.
# Generate with: npm run generate-key
# Provide at least PRIVATE_KEY_1; add more to enable key rotation.
# PRIVATE_KEY_1=
# PRIVATE_KEY_2=
# PRIVATE_KEY_3=
