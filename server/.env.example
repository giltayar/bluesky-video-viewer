# --- Server ---
# Port and host the backend listens on
PORT=3000
HOST=127.0.0.1

# Public origin of the backend (used to build OAuth redirect_uri / metadata URLs).
# In local dev this must be a loopback IP (127.0.0.1), NOT "localhost".
PUBLIC_URL=http://127.0.0.1:3000

# Where the browser app is served (the OAuth callback redirects here).
FRONTEND_URL=http://127.0.0.1:5173

# Secret used to sign the app-session cookie. Change this to a long random value.
COOKIE_SECRET=change-me-to-a-long-random-string

# --- Production OAuth (confidential client) ---
# Set NODE_ENV=production to use the confidential client below.
# NODE_ENV=production
#
# Public URL that serves the client metadata document (usually PUBLIC_URL/client-metadata.json)
# CLIENT_ID=https://your-domain.example/client-metadata.json
#
# One or more ES256 private keys (PEM or JWK JSON), used to sign client assertions.
# Provide at least one; more allow key rotation.
# PRIVATE_KEY_1=
# PRIVATE_KEY_2=
# PRIVATE_KEY_3=
